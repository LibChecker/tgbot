{
  "name": "@tgbot/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./apk.js": "./src/apk.js",
    "./apk-signatures.js": "./src/apk-signatures.js",
    "./contracts.js": "./src/contracts.js",
    "./i18n.js": "./src/i18n.js",
    "./sdk-markers.js": "./src/sdk-markers.js",
    "./terminal-system.js": "./src/terminal-system.js",
    "./generated/*": "./src/generated/*"
  },
  "scripts": {
    "i18n:generate": "node scripts/generate_i18n_catalogs.mjs",
    "i18n:check": "node scripts/generate_i18n_catalogs.mjs --check",
    "generated:generate": "node scripts/generate_shared_assets.mjs",
    "generated:refresh": "node scripts/generate_shared_assets.mjs --refresh",
    "rules:update": "python scripts/generate_libchecker_bundle.py",
    "syntax:check": "node scripts/check.mjs",
    "test": "node --test test/*.test.mjs",
    "check": "npm run generated:generate && npm run i18n:check && npm run syntax:check && npm test"
  }
}
