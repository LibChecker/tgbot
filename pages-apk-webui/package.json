{
  "name": "@tgbot/apk-webui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../scripts/generate_shared_assets.mjs && node scripts/build.mjs",
    "check": "node ../scripts/generate_shared_assets.mjs && node scripts/check.mjs",
    "dev": "node ../scripts/generate_shared_assets.mjs && vite --config vite.config.mjs",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=tgbot-apk-webui"
  },
  "devDependencies": {
    "vite": "^8.0.16"
  }
}
